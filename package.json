{
  "name": "laserforge",
  "version": "1.0.0",
  "description": "",
  "main": "dist-electron/main.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "tsc -p electron/tsconfig.json && electron dist-electron/main.js",
    "electron:build": "npm run build && tsc -p electron/tsconfig.json && electron-builder",
    "test": "npx tsx tests/pipeline.test.ts && npx tsx tests/controller.test.ts && npx tsx tests/simulation.test.ts && npx tsx tests/viewport.test.ts && npx tsx tests/svg-import.test.ts && npx tsx tests/svg-import-placement.test.ts && npx tsx tests/history.test.ts && npx tsx tests/scene-io.test.ts && npx tsx tests/ui-integration.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.laserforge.app",
    "productName": "LaserForge",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "polygon-clipping": "^0.15.7",
    "potrace-js": "^0.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
