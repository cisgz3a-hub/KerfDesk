{
  "name": "laserforge",
  "version": "1.0.0",
  "description": "Laser cutting and engraving software",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "npm run electron:compile && electron dist-electron/main.js",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "icons:ico": "node scripts/generate-ico.mjs",
    "electron:build": "npm run build && npm run electron:compile && npm run icons:ico && electron-builder --win",
    "electron:build:mac": "npm run build && npm run electron:compile && npm run icons:ico && electron-builder --mac",
    "test": "npx tsx tests/pipeline.test.ts && npx tsx tests/controller.test.ts && npx tsx tests/simulation.test.ts && npx tsx tests/viewport.test.ts && npx tsx tests/svg-import.test.ts && npx tsx tests/svg-import-placement.test.ts && npx tsx tests/history.test.ts && npx tsx tests/scene-io.test.ts && npx tsx tests/ui-integration.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.laserforge.app",
    "productName": "LaserForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LaserForge"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png",
      "category": "public.app-category.graphics-design"
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.9",
    "polygon-clipping": "^0.15.7",
    "potrace-js": "^0.0.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
