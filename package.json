{
  "name": "laserforge",
  "version": "0.0.0",
  "private": true,
  "description": "Focused GRBL CAM application for laser cutters and engravers. Web + Windows desktop from one codebase. MIT.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.3.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "license-check": "license-checker --production --excludePackages \"laserforge@0.0.0\" --onlyAllow \"MIT;MIT-0;BSD-2-Clause;BSD-3-Clause;Apache-2.0;Apache-2.0 AND MIT;MPL-2.0;ISC;Unlicense;0BSD;(MPL-2.0 OR Apache-2.0);CC-BY-4.0;CC0-1.0;Python-2.0\" --summary",
    "dev:web": "vite",
    "build:web": "tsc --noEmit && vite build",
    "preview:web": "vite preview",
    "build:electron-main": "tsc --project electron/tsconfig.json",
    "dev:desktop": "pnpm build:electron-main && vite build && electron .",
    "build:desktop": "pnpm build:electron-main && vite build && electron-builder --win --x64",
    "electron:start": "electron .",
    "deploy:web": "pnpm build:web && wrangler pages deploy dist/web --project-name=laserforge --branch=master",
    "deploy:web:preview": "pnpm build:web && wrangler pages deploy dist/web --project-name=laserforge --branch=preview"
  },
  "dependencies": {
    "dompurify": "^3.3.2",
    "imagetracerjs": "^1.2.6",
    "opentype.js": "^2.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^20.14.0",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^42.3.0",
    "electron-builder": "^26.11.1",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fast-check": "^3.22.0",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "license-checker": "^25.0.1",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.6.0",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.95.0"
  }
}
