{
  "name": "laserforge",
  "version": "0.1.0",
  "private": true,
  "description": "Focused GRBL CAM application for laser cutters, engravers, and CNC routers. Web + Windows desktop from one codebase. MIT licensed.",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.3.0 <12"
  },
  "packageManager": "pnpm@11.3.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "lint": "eslint .",
    "lint:electron": "eslint --config eslint.electron.config.mjs electron/**/*.ts",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chrome",
    "typecheck:e2e": "tsc --noEmit -p e2e/tsconfig.json",
    "license-check": "node scripts/check-licenses.mjs",
    "audit:deps": "pnpm audit --audit-level=low",
    "check:file-size": "node scripts/check-file-size-policy.mjs",
    "check:soft-size": "node scripts/check-soft-line-limit.mjs",
    "check:index-exports": "node scripts/check-index-exports.mjs",
    "release:check": "pnpm typecheck && pnpm lint && pnpm lint:electron && pnpm format:check && pnpm license-check && pnpm audit:deps && pnpm test && pnpm build:web && pnpm build:electron-main && pnpm check:file-size && pnpm check:soft-size && pnpm check:index-exports",
    "guard:repo": "node scripts/assert-correct-repo.mjs",
    "dev:web": "vite",
    "build": "pnpm build:web",
    "generate:notices": "node scripts/generate-third-party-notices.mjs",
    "build:web": "pnpm generate:notices && tsc --noEmit && vite build",
    "preview:web": "vite preview",
    "build:electron-main": "node scripts/clean-electron-output.mjs && tsc --project electron/tsconfig.json",
    "dev:desktop": "pnpm build:electron-main && vite build && electron .",
    "build:desktop": "pnpm build:electron-main && vite build && electron-builder --win --x64",
    "electron:start": "electron .",
    "camera:bridge": "pnpm build:electron-main && node dist-electron/rtsp-camera-bridge-cli.js",
    "deploy:web": "pnpm guard:repo && pnpm release:check && wrangler pages deploy dist/web --project-name=laserforge --branch=main",
    "deploy:web:preview": "pnpm guard:repo && pnpm release:check && wrangler pages deploy dist/web --project-name=laserforge --branch=preview"
  },
  "dependencies": {
    "clipper2-ts": "2.0.1-17",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "imagetracerjs": "^1.2.6",
    "lucide-static": "^1.23.0",
    "opentype.js": "^2.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "three": "^0.180.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.6",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fast-check": "^3.22.0",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.6.0",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.100.0"
  }
}
