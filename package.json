{
  "name": "laserforge",
  "version": "1.0.0",
  "description": "Laser cutting and engraving software",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/verify-production-build.mjs",
    "preview": "vite preview",
    "electron:dev": "npm run electron:compile && concurrently -k -n vite,electron -c green,cyan \"npm run dev\" \"wait-on http://localhost:3000 && electron dist-electron/main.js\"",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "icons:ico": "node scripts/generate-ico.mjs",
    "electron:build": "npm run build && npm run electron:compile && npm run icons:ico && electron-builder --win",
    "electron:build:mac": "npm run build && npm run electron:compile && npm run icons:ico && electron-builder --mac",
    "license-check": "node scripts/license-check.mjs",
    "license-check:report": "node scripts/license-check-report.mjs",
    "license-check:summary": "node scripts/license-check-summary.mjs",
    "test": "node scripts/run-tests.mjs",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "_npmRebuildRationale": "T1-86 originally documented why npmRebuild=false was acceptable while serialport was shipped. T2-35 removed the unused Electron native serialport bridge instead: the renderer uses Web Serial through MachineService/GrblController, and package.json now has no production native Node modules. npmRebuild remains false because there is currently nothing native for electron-builder to rebuild; tests/native-deps-prebuild-check.test.ts asserts this no-production-native-module invariant. Re-evaluate this decision if a future production native dependency is added.",
  "build": {
    "appId": "com.laserforge.app",
    "productName": "LaserForge",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "dist-electron/**/*",
      "!dist-electron/**/*.map",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LaserForge"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png",
      "category": "public.app-category.graphics-design"
    }
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.1",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "license-checker-rseidelsohn": "^4.4.2",
    "png-to-ico": "^3.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.5",
    "wait-on": "^7.2.0",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "dompurify": "^3.4.1",
    "floyd-steinberg": "^1.0.6",
    "imagetracerjs": "^1.2.6",
    "opentype.js": "^1.3.4",
    "polygon-clipping": "^0.15.7",
    "polygon-offset": "^0.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.13"
  }
}
