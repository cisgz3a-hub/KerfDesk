# Keep text byte-identical across Linux and Windows release runners. Prettier
# enforces LF, so relying on a runner's core.autocrlf setting makes the Windows
# packaging gate report the entire checkout as unformatted.
* text=auto eol=lf

# Treat binary assets as binary explicitly, so git's autocrlf logic
# never tries to "fix" line endings inside them. The previous Dancing
# Script font failed to parse because the download was an HTML error
# page (which IS text and got CRLF-normalized) committed under a .ttf
# name. Forcing -text on these patterns makes that class of bug
# fail loudly at download time instead of silently corrupting the
# binary on commit.
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.pdf binary
*.gcode binary
*.lf2 binary

# External compatibility fixtures are retained byte-for-byte so the pinned
# upstream SHA-256 provenance remains verifiable after checkout.
src/__fixtures__/lightburn/external/clb/** -text
src/__fixtures__/lightburn/external/lbrn/** -text
