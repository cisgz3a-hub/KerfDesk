{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist-electron",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
